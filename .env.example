# Server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Google Sheets
GOOGLE_SHEETS_SPREADSHEET_ID=your-google-spreadsheet-id
GOOGLE_SHEETS_SHEET_NAME=Demo Requests
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key\n-----END PRIVATE KEY-----"

# SMTP
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-smtp-username
MAIL_PASS=your-smtp-password
MAIL_FROM="Avail <hello@example.com>"
MAIL_REPLY_TO=hello@example.com

# Notifications
TEAM_NOTIFICATION_EMAILS=team@example.com
